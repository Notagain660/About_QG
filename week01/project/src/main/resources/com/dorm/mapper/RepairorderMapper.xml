<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dorm.mapper.RepairorderMapper">

    <insert id="insertRepairorder" parameterType="com.dorm.entity.Repairorder" useGeneratedKeys="true" keyProperty="orderId">
        INSERT INTO repairorder (id, dormBuilding, roomNumber, phoneNumber, deviceType, status, descriptionText, createTime, updateTime, processTime, priorityLevel, comments)
        VALUES (#{id}, #{dormBuilding}, #{roomNumber}, #{phoneNumber}, #{deviceType}, #{status}, #{descriptionText}, Now(), Now(), NULL, #{priorityLevel}, #{comments})
    </insert>

    <select id="selectByUserId" parameterType="string" resultType="com.dorm.entity.Repairorder">
        SELECT * FROM repairorder WHERE id = #{id} ORDER BY orderId
    </select>

    <select id="selectAll" resultType="com.dorm.entity.Repairorder">
        SELECT * FROM repairorder ORDER BY orderId
    </select>

    <select id="selectByOrderId" parameterType="long" resultType="com.dorm.entity.Repairorder">
        SELECT * FROM repairorder WHERE orderId = #{orderId}
    </select>

    <select id="selectByStatus" parameterType="string" resultType="com.dorm.entity.Repairorder">
        SELECT * FROM repairorder WHERE status = #{status}
    </select>

    <select id="selectByCreateTime" parameterType="java.util.Date" resultType="com.dorm.entity.Repairorder">
        SELECT * FROM repairorder WHERE createTime = #{createTime}
    </select>

    <select id="selectByUpdateTime" parameterType="java.util.Date" resultType="com.dorm.entity.Repairorder">
        SELECT * FROM repairorder WHERE updateTime = #{updateTime}
    </select>

    <select id="selectByProcessTime" parameterType="java.util.Date" resultType="com.dorm.entity.Repairorder">
        SELECT * FROM repairorder WHERE processTime = #{processTime}
    </select>

    <update id="updateRepairorder" parameterType="com.dorm.entity.Repairorder">
        UPDATE repairorder
        SET
        phoneNumber = #{phoneNumber},
        descriptionText = #{descriptionText},
        status = #{status},
        updateTime = Now(),
        processTime = Now()
        WHERE orderId = #{orderId}
    </update>

    <delete id="deleteByOrderId" parameterType="com.dorm.entity.Repairorder">
        DELETE FROM repairorder WHERE orderId = #{orderId}
    </delete>

</mapper>